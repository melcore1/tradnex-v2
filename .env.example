# === Required (Phase 0) ===
DATABASE_PATH=/data/tradnex.db
LOG_LEVEL=info
ENVIRONMENT=dev               # one of: dev | paper | live

# === Data layer (Phase 1a) ===
DATA_CLIENT=mock              # 'mock' for dev / before approval; 'schwab' once approved
MOCK_SEED=42                  # determinism for MockDataClient

# === Schwab credentials ===
# Phase 8a.5: Client ID / Client Secret and OAuth tokens now live in the
# encrypted credentials table. Configure via Settings → Credentials →
# Schwab in the UI. The env vars below are kept only for the legacy
# `scripts/schwab_auth.py` bootstrap path; new installs should leave
# them blank.
# SCHWAB_CLIENT_ID=
# SCHWAB_CLIENT_SECRET=
# SCHWAB_TOKEN_PATH=/data/schwab_token.json
#
# The redirect URI MUST match what's registered on your Schwab Developer
# App and MUST be reachable over HTTPS (Schwab rejects plain-HTTP
# callbacks). For local dev, terminate TLS via Caddy + a local cert.
SCHWAB_REDIRECT_URI=https://<your-domain>/api/schwab/oauth/callback
SCHWAB_OAUTH_ENABLED=true

# === Halt feed source (Phase 1d) ===
HALT_FEED=mock                                # 'mock' for dev, 'nasdaq' for live
HALT_POLL_MARKET_SECONDS=30                   # poll interval during market hours
HALT_POLL_OFF_HOURS_SECONDS=300               # poll interval outside market hours

# === Phase 8a — encrypted credentials store ===
# Master Fernet key for the credentials table. The ONLY env-resident
# credential after Phase 8a; all provider keys live in the DB encrypted
# with this key. Generate via:
#     python -m services.api.cli generate-encryption-key
# Rotating this key invalidates every existing credentials row, so back
# it up alongside the .env file.
ENCRYPTION_KEY=

# === Provider keys (auto-migrated to credentials store) ===
# These two are AUTO-MIGRATED to the encrypted credentials store on first
# startup. After migration, env values are ignored and the UI
# (/settings/credentials) is the source of truth. New installs should
# leave these blank and add keys through the frontend.
FINNHUB_API_KEY=
EXA_API_KEY=

# === Required for Phase 5 (Claude evaluator news research) ===
CLAUDE_CLIENT=mock              # 'mock' for dev/CI, 'cli' to invoke `claude -p` subprocess
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_TIMEOUT_SECONDS=90
CLAUDE_CLI_PATH=claude          # absolute path if `claude` isn't on PATH

# === Phase 6 (FastAPI) ===
API_HOST=0.0.0.0
API_PORT=8080
SESSION_DURATION_DAYS=30
SESSION_COOKIE_NAME=tradnex_session
SESSION_COOKIE_SECURE=true                # set false for local HTTP dev
SESSION_COOKIE_SAMESITE=strict
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_WINDOW_SECONDS=900          # 15 min sliding window
LOGIN_LOCKOUT_DURATION_SECONDS=3600       # 1 hour lockout
CORS_ALLOW_ORIGINS=                       # comma-separated; empty = same-origin only
SSE_POLL_INTERVAL_SECONDS=1.0

# Bearer token kept around for non-cookie clients (CI / scripts)
API_BEARER_TOKEN=

# === Phase 7 (Next.js frontend + Caddy reverse proxy) ===
# Caddy fronts both api and frontend on this port (default 80).
CADDY_HTTP_PORT=80
# API base for the frontend's runtime fetch. Empty in production —
# same-origin via Caddy. Set to http://localhost:8080 for the
# host-side `npm run dev` flow.
NEXT_PUBLIC_API_BASE=
# Internal URL the Next.js middleware uses to validate sessions
# during SSR (inside the docker network).
API_INTERNAL_URL=http://api:8080

# === Notifications (used from Phase 4 onward) ===
NTFY_TOPIC=tradnex_dev_CHANGE_ME
