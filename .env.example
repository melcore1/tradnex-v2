# === Required (Phase 0) ===
DATABASE_PATH=/data/tradnex.db
LOG_LEVEL=info
ENVIRONMENT=dev               # one of: dev | paper | live

# === Data layer (Phase 1a) ===
DATA_CLIENT=mock              # 'mock' for dev / before approval; 'schwab' once approved
MOCK_SEED=42                  # determinism for MockDataClient

# === Schwab credentials (fill in when API approved) ===
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=https://127.0.0.1:8443
SCHWAB_TOKEN_PATH=/data/schwab_token.json

# === Required for Phase 4 (hard vetoes / calendar) ===
FINNHUB_API_KEY=

# === Required for Phase 5 (Claude evaluator news research) ===
EXA_API_KEY=

# === Required for Phase 6 (FastAPI auth) ===
API_BEARER_TOKEN=

# === Notifications (used from Phase 4 onward) ===
NTFY_TOPIC=tradnex_dev_CHANGE_ME
