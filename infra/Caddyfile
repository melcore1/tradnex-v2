# Caddy 2 reverse proxy for TradNex.
# Routes:
#   /api/events/stream*  → API (long-lived SSE, no buffering)
#   /api/*               → API
#   /*                   → Frontend (Next.js)
#
# Phase 7: LAN-only HTTP on port 80. CF Tunnel exposure deferred.

{
    auto_https off
    admin off
    persist_config off
}

:80 {
    # SSE — keep the connection open, flush each chunk immediately.
    @sse path /api/events/stream*
    handle @sse {
        reverse_proxy api:8080 {
            flush_interval -1
            transport http {
                read_timeout 0
                response_header_timeout 0
            }
        }
    }

    # All other API routes
    handle /api/* {
        reverse_proxy api:8080
    }

    # Frontend (catch-all)
    handle {
        reverse_proxy frontend:3000
    }

    encode gzip

    log {
        output stdout
        format console
        level INFO
    }
}
